# URL publique du site (optionnel : Open Graph / metadata absolues en prod)
# NEXT_PUBLIC_SITE_URL=https://votre-domaine.com

# --- Backend API ---
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- Postgres (optionnel mais recommandé : compte / historique / sync paiement) ---
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# --- Admin interne (page /admin?token=...) ---
# Genere une valeur longue aleatoire et garde-la secrete.
ATTENTIQ_ADMIN_TOKEN=

# --- Stripe : clés ---
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxx
STRIPE_SECRET_KEY=sk_test_xxxxx

# --- Stripe : Payment Links (URLs buy.stripe.com/...) ---
NEXT_PUBLIC_STRIPE_LINK_SINGLE=
NEXT_PUBLIC_STRIPE_LINK_MONTHLY5=
# Tier 89€/mois : NEXT_PUBLIC_STRIPE_LINK_PACK_15 ou ancien nom :
NEXT_PUBLIC_STRIPE_LINK_PACK_15=
# NEXT_PUBLIC_STRIPE_LINK_UNLIMITED=

# Optionnel : préremplit l'email sur les Payment Links (serveur, /api/checkout/prepare).
# Ex. tests avec votre adresse de facturation Stripe.
STRIPE_CHECKOUT_PREFILL_EMAIL=

# Optionnel : même usage côté navigateur (ex. dev local).
NEXT_PUBLIC_STRIPE_PREFILL_EMAIL=

# --- Stripe : Price IDs (serveur, ex. POST /api/checkout) ---
STRIPE_PRICE_SINGLE_REPORT=
STRIPE_PRICE_SINGLE_REPORT_9=
STRIPE_PRICE_MONTHLY_29=
STRIPE_PRICE_PACK_15=
STRIPE_PRICE_MONTHLY_89=

# Après paiement : success URL des Payment Links doit renvoyer vers
# https://<ton-domaine>/merci?session_id={CHECKOUT_SESSION_ID}
# (et pour l'unitaire depuis /analyze, le cookie checkout garde jobId + videoUrl)
