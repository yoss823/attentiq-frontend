# Backend API URL (FastAPI service)
# In Railway: set this to your attentiqbackend service's internal URL
NEXT_PUBLIC_API_URL=http://localhost:8000

# Stripe Configuration
# Get these from your Stripe Dashboard: https://dashboard.stripe.com

# Public key (safe to expose in frontend)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxx

# Secret key (NEVER expose, server-only)
STRIPE_SECRET_KEY=sk_test_xxxxx

# Price IDs for the 3 products (create in Stripe Dashboard)
# 1. Rapport Complet - 19€ one-time
NEXT_PUBLIC_STRIPE_PRICE_ID_19=price_xxxxx

# 2. 5 Rapports/mois - 49€ recurring monthly
NEXT_PUBLIC_STRIPE_PRICE_ID_49=price_xxxxx

# 3. Illimité/mois - 99€ recurring monthly
NEXT_PUBLIC_STRIPE_PRICE_ID_99=price_xxxxx
